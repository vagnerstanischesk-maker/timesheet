<?xml version = "1.0" encoding = "ISO-8859-1"?>
<!DOCTYPE taglib PUBLIC "-//Sun Microsystems, Inc.//DTD JSP Tag Library 1.1//EN" "file:///D:/temp/ojsp/oracle/jsp/parse/web-jsptaglibrary_1_1.dtd">
<taglib xmlns = "http://java.sun.com/j2ee/dtds/web-jsptaglibrary_1_1.dtd">
   <tlibversion>3.2</tlibversion>
   <jspversion>1.1</jspversion>
   <shortname>DataTags</shortname>
   <info>The BC4J DataTag library</info>   
   <tag>
      <name>ApplicationModule</name>
      <tagclass>oracle.jbo.html.jsp.datatags.ApplicationModuleTag</tagclass>
      <bodycontent>empty</bodycontent>
      <info>A Tag to insert a Data Application into a page.</info>    
      <attribute>
         <name>id</name>
         <required>true</required>
      </attribute>            
      <attribute>
         <name>configname</name>
         <required>true</required>
      </attribute>
      <attribute>
         <name>username</name>
         <required>false</required>
      </attribute>      
      <attribute>
         <name>password</name>
         <required>false</required>
      </attribute>
      <attribute>
         <name>iiop_username</name>
         <required>false</required>
      </attribute>
      <attribute>
         <name>iiop_password</name>
         <required>false</required>
      </attribute>
   </tag>   
   <tag>
      <name>DataSource</name>
      <tagclass>oracle.jbo.html.jsp.datatags.ViewObjectTag</tagclass>    
      <teiclass>oracle.jbo.html.jsp.datatags.ViewObjectTEI</teiclass>
      <bodycontent>JSP</bodycontent>
      <info>A Tag to insert a View Object DataSource into a page.</info>    
     <attribute>
         <name>id</name>
         <required>true</required>
      </attribute>
      <attribute>
         <name>appid</name>
         <required>true</required>
         <rtexprvalue>true</rtexprvalue>
      </attribute>
      <attribute>
         <name>viewobject</name>
         <required>true</required>
      </attribute>    
      <attribute>
         <name>whereclause</name>
         <required>false</required>      
         <rtexprvalue>true</rtexprvalue>
      </attribute>      
      <attribute>
         <name>rangesize</name>
         <required>false</required>      
         <rtexprvalue>true</rtexprvalue>
      </attribute>
   </tag>
   <tag>
      <name>CreateViewObject</name>
      <tagclass>oracle.jbo.html.jsp.datatags.DynamicViewObjectTag</tagclass>
      <bodycontent>JSP</bodycontent>
      <info>A Tag to insert a Dynamic View Object into a page.</info>
      <attribute>
         <name>appid</name>
         <required>true</required>
      </attribute>    
      <attribute>
         <name>name</name>
         <required>true</required>
      </attribute>      
      <attribute>
         <name>rangesize</name>
         <required>false</required>      
         <rtexprvalue>true</rtexprvalue>
      </attribute>
   </tag>

   <tag>
      <name>Row</name>
      <tagclass>oracle.jbo.html.jsp.datatags.RowTag</tagclass>      
      <teiclass>oracle.jbo.html.jsp.datatags.RowTagTEI</teiclass>
      <bodycontent>JSP</bodycontent>
      <info>A Tag to locate a row in a rowset.</info>    
      <attribute>
         <name>id</name>
         <required>true</required>
      </attribute>
      <attribute>
         <name>datasource</name>
         <required>true</required>
         <rtexprvalue>true</rtexprvalue>
      </attribute>    
      <attribute>
         <name>action</name>
         <required>true</required>      
         <rtexprvalue>true</rtexprvalue>
      </attribute>
      <attribute>
         <name>rowkeyparam</name>
         <required>false</required>      
         <rtexprvalue>true</rtexprvalue>
      </attribute>    
      <attribute>
         <name>rowkey</name>
         <required>false</required>      
         <rtexprvalue>true</rtexprvalue>
      </attribute>    
   </tag>  
   <tag>
      <name>RowsetNavigate</name>
      <tagclass>oracle.jbo.html.jsp.datatags.DataNavigateTag</tagclass>
      <bodycontent>empty</bodycontent>
      <info>A Tag to insert a Data Navigate into a page.</info>
      <attribute>
         <name>datasource</name>
         <required>true</required>
         <rtexprvalue>true</rtexprvalue>
      </attribute>      
      <attribute>
         <name>action</name>
         <required>true</required>      
         <rtexprvalue>true</rtexprvalue>
      </attribute>
   </tag>   
   <tag>
      <name>RowsetIterate</name>
      <tagclass>oracle.jbo.html.jsp.datatags.DataLoopTag</tagclass>
      <bodycontent>JSP</bodycontent>
      <info>A Tag to insert a Data Loop into a page.</info>
      <attribute>
         <name>datasource</name>
         <required>true</required>
         <rtexprvalue>true</rtexprvalue>
      </attribute>
   </tag>  
   <tag>
      <name>RefreshDataSource</name>
      <tagclass>oracle.jbo.html.jsp.datatags.RefreshDataSource</tagclass>
      <bodycontent>empty</bodycontent>
      <info>A Tag to re-execute a Datasource's data from the database.</info>
      <attribute>
         <name>datasource</name>
         <required>true</required>
         <rtexprvalue>true</rtexprvalue>
      </attribute>
   </tag>   
   <tag>
      <name>ShowValue</name>
      <tagclass>oracle.jbo.html.jsp.datatags.DataValueTag</tagclass>
      <bodycontent>tagdependent</bodycontent>
      <info>A Tag to insert a Data Value into a page.</info>      
      <attribute>
         <name>datasource</name>
         <required>true</required>         
         <rtexprvalue>true</rtexprvalue>
      </attribute>      
      <attribute>
         <name>dataitem</name>
         <required>true</required>         
         <rtexprvalue>true</rtexprvalue>
      </attribute>
   </tag>    
   <tag>
      <name>RenderValue</name>
      <tagclass>oracle.jbo.html.jsp.datatags.DisplayTag</tagclass>
