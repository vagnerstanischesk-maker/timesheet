      </attribute>
   </tag>   
   <tag>
      <name>SetAttribute</name>
      <tagclass>oracle.jbo.html.jsp.datatags.SetAttributeTag</tagclass>
      <bodycontent>empty</bodycontent>
      <info>A Tag to update an attribute in a row.</info>      
      <attribute>
         <name>dataitem</name>
         <required>true</required>      
         <rtexprvalue>true</rtexprvalue>
      </attribute>    
      <attribute>
         <name>value</name>
         <required>false</required>
         <rtexprvalue>true</rtexprvalue>
      </attribute>
        <attribute>
         <name>usemultipartformat</name>
         <required>false</required>
         <rtexprvalue>true</rtexprvalue>
      </attribute>
   </tag>   
