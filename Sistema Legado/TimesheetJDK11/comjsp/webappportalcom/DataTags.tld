      </attribute>
      <attribute>
         <name>datasource</name>
         <required>true</required>         
         <rtexprvalue>true</rtexprvalue>
      </attribute>      
      <attribute>
         <name>dataitem</name>
         <required>true</required>         
         <rtexprvalue>true</rtexprvalue>
      </attribute>      
      <attribute>
         <name>displaydatasource</name>
         <required>true</required>         
         <rtexprvalue>true</rtexprvalue>
      </attribute>      
      <attribute>
         <name>displaydataitem</name>
         <required>true</required>         
         <rtexprvalue>true</rtexprvalue>
      </attribute>      
      <attribute>
         <name>displayvaluedataitem</name>
         <required>true</required>         
         <rtexprvalue>true</rtexprvalue>
      </attribute>      
   </tag>   
